# =============================================================================
# MedicalTrackingApp — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# .env is gitignored and must NEVER be committed to version control.
# =============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────

# Secret key used for cryptographic signing. MUST be long, random, and unique.
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-me

# Run the server in debug mode. Set to False in production.
DEBUG=True

# Comma-separated list of allowed hostnames.
# Examples:
#   Development : ALLOWED_HOSTS=localhost,127.0.0.1
#   Production  : ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1
